# Example environment for the voice-trigger compose stack.
# Copy to ../secrets/.env and edit. The web UI also writes this file.
#
# HA / Ollama run separately on your LAN — only their URLs/tokens go here.

# Home Assistant (required)
HA_URL=http://192.168.1.2:8123
HA_TOKEN=

# Ollama (optional — not used in the realtime path yet)
OLLAMA_URL=http://192.168.1.2:11434
OLLAMA_TOKEN=
